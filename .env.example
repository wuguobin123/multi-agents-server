APP_CONFIG_PATH=configs/app.yaml

MODEL_PROVIDER=minimax
MODEL_NAME=MiniMax-M2.5-highspeed
MODEL_TIMEOUT_SECONDS=60
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

BROWSER_USE_CDP_URL=http://119.45.252.25:9223
BROWSER_USE_REMOTE_HEALTH_URL=http://119.45.252.25:8787/health
BROWSER_USE_REMOTE_INFO_URL=http://119.45.252.25:8787/v1/browser/info
BROWSER_USE_REMOTE_BEARER_TOKEN=
BROWSER_USE_MAX_STEPS=6
BROWSER_USE_MAX_FAILURES=1
BROWSER_USE_RETRY_DELAY=2
BROWSER_USE_MAX_ACTIONS_PER_STEP=4
BROWSER_USE_USE_VISION=false
BROWSER_USE_DISABLE_ENV_PROXY=true

DATABASE_ENABLED=true
DATABASE_URL=mysql+pymysql://multi_agents:multi_agents@mysql:3306/multi_agents
DATABASE_AUTO_INIT=true

RAG_VECTOR_STORE_BACKEND=qdrant
RAG_COLLECTION_NAME=knowledge_chunks
RAG_BOOTSTRAP_ON_STARTUP=true
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embedding
EMBEDDING_DIMENSION=256
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=20
EMBEDDING_MAX_RETRIES=2
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

BOOTSTRAP_KB_ON_STARTUP=true
FORCE_KB_REBUILD=false

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=INFO
APP_REQUEST_TIMEOUT_SECONDS=90
