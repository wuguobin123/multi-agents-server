APP_CONFIG_PATH=configs/app.yaml

MODEL_PROVIDER=minimax
MODEL_NAME=MiniMax-M2.5-highspeed
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

DATABASE_ENABLED=true
DATABASE_URL=mysql+pymysql://multi_agents:multi_agents@mysql:3306/multi_agents
DATABASE_AUTO_INIT=true

RAG_VECTOR_STORE_BACKEND=qdrant
RAG_COLLECTION_NAME=knowledge_chunks
RAG_BOOTSTRAP_ON_STARTUP=true
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embedding
EMBEDDING_DIMENSION=256
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=20
EMBEDDING_MAX_RETRIES=2
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

BOOTSTRAP_KB_ON_STARTUP=true
FORCE_KB_REBUILD=false

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=INFO
